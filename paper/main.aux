\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Repository-level metrics on the 50-example Tangut test set. The Frontier DeepSeek row is a proprietary prompt-only upper bound using dictionary grounding plus four development-set few-shot exemplars. Here \texttt  {g0.2} and \texttt  {g0.4} denote minimum preference-gap thresholds of 0.2 and 0.4. Bold marks the best local learned value in each column, excluding prompt-only baselines and the human reference. The key comparison is no longer ``prompting versus training'' in the abstract: frontier prompting is strongest on several reference-free metrics, but strict gap-$0.4$ multitask DPO still gives the best non-reference chrF++ and the strongest local raw-overlap result.}}{7}{table.1}\protected@file@percent }
\newlabel{tab:main-results}{{1}{7}{Repository-level metrics on the 50-example Tangut test set. The Frontier DeepSeek row is a proprietary prompt-only upper bound using dictionary grounding plus four development-set few-shot exemplars. Here \texttt {g0.2} and \texttt {g0.4} denote minimum preference-gap thresholds of 0.2 and 0.4. Bold marks the best local learned value in each column, excluding prompt-only baselines and the human reference. The key comparison is no longer ``prompting versus training'' in the abstract: frontier prompting is strongest on several reference-free metrics, but strict gap-$0.4$ multitask DPO still gives the best non-reference chrF++ and the strongest local raw-overlap result}{table.1}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6}Analysis}{8}{section.6}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.1}Reference-aligned diagnostics}{8}{subsection.6.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Oracle complementarity and workflow value}{8}{subsection.6.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Reference-aligned diagnostics derived from stored predictions. ``Contam.'' denotes mixed-script or artifact contamination. In the last two columns, the table reports suffix-preservation count first and length ratio second. Bold marks the best local learned value in each column, excluding prompt-only baselines and the human reference. The frontier DeepSeek row shows that strong prompt-only inference can already reconstruct many short titles cleanly, while the new gap-$0.4$ local DPO variants keep most of the suffix gains of multitask-base DPO and restore near-reference length relative to their gap-$0.2$ counterparts.}}{9}{table.2}\protected@file@percent }
\newlabel{tab:diagnostics}{{2}{9}{Reference-aligned diagnostics derived from stored predictions. ``Contam.'' denotes mixed-script or artifact contamination. In the last two columns, the table reports suffix-preservation count first and length ratio second. Bold marks the best local learned value in each column, excluding prompt-only baselines and the human reference. The frontier DeepSeek row shows that strong prompt-only inference can already reconstruct many short titles cleanly, while the new gap-$0.4$ local DPO variants keep most of the suffix gains of multitask-base DPO and restore near-reference length relative to their gap-$0.2$ counterparts}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Complementarity between the strongest frontier and local systems. The two systems produce identical outputs on only 4/50 items, so the oracle is not just restating a near-duplicate ranking. Instead, it shows that local adaptation supplies genuinely different useful hypotheses: selecting the better output of the two systems yields large gains on both raw overlap and reference-aware utility.}}{9}{table.3}\protected@file@percent }
\newlabel{tab:oracle-complementarity}{{3}{9}{Complementarity between the strongest frontier and local systems. The two systems produce identical outputs on only 4/50 items, so the oracle is not just restating a near-duplicate ranking. Instead, it shows that local adaptation supplies genuinely different useful hypotheses: selecting the better output of the two systems yields large gains on both raw overlap and reference-aware utility}{table.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}A direct test of stronger CoT prompting}{9}{subsection.6.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Reference-aware judge scores on a 1--5 scale. The judge sees the Tangut input, the gold reference, and the candidate output simultaneously. Bold marks the best local learned value in each column, excluding prompt-only baselines and the human reference. The frontier DeepSeek baseline is the strongest non-reference system overall, but within the local family the best overall score is shared by three multitask-base DPO variants; the stricter gap-$0.4$ runs win the local tie-break dimensions, with MT-DPO g0.4 sig leading on reference agreement and source faithfulness and MT-DPO g0.4 rob leading on title-style fitness.}}{10}{table.4}\protected@file@percent }
\newlabel{tab:reference-aware-eval}{{4}{10}{Reference-aware judge scores on a 1--5 scale. The judge sees the Tangut input, the gold reference, and the candidate output simultaneously. Bold marks the best local learned value in each column, excluding prompt-only baselines and the human reference. The frontier DeepSeek baseline is the strongest non-reference system overall, but within the local family the best overall score is shared by three multitask-base DPO variants; the stricter gap-$0.4$ runs win the local tie-break dimensions, with MT-DPO g0.4 sig leading on reference agreement and source faithfulness and MT-DPO g0.4 rob leading on title-style fitness}{table.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.4}Reference-aware judging changes the ranking}{10}{subsection.6.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Paired bootstrap comparisons with 5,000 resamples. ``Overall'' denotes the mean reference-aware judge score, and ``Exact'' denotes exact-match rate. The table shows that the local chrF++ gain over multitask SFT is robust, while the frontier system retains a robust advantage over the best local model on reference-aware overall and exact match.}}{11}{table.5}\protected@file@percent }
\newlabel{tab:statistical-robustness}{{5}{11}{Paired bootstrap comparisons with 5,000 resamples. ``Overall'' denotes the mean reference-aware judge score, and ``Exact'' denotes exact-match rate. The table shows that the local chrF++ gain over multitask SFT is robust, while the frontier system retains a robust advantage over the best local model on reference-aware overall and exact match}{table.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.5}Human-reference anchor}{11}{subsection.6.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.6}Statistical robustness and data hygiene}{11}{subsection.6.6}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Lightweight audit of the current DPO pair construction pipeline. Higher reward gaps correlate with cleaner preference labels under a simple gold-proxy check, which helps explain why strict filtering stabilizes the later multitask-base DPO runs.}}{12}{table.6}\protected@file@percent }
\newlabel{tab:dpo-audit}{{6}{12}{Lightweight audit of the current DPO pair construction pipeline. Higher reward gaps correlate with cleaner preference labels under a simple gold-proxy check, which helps explain why strict filtering stabilizes the later multitask-base DPO runs}{table.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.7}Legacy DPO fails for different reasons than multitask-base DPO}{12}{subsection.6.7}\protected@file@percent }
