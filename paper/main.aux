\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}RQ1: Is strong frontier prompting already enough as a single-model upper bound?}{6}{subsection.5.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Representative systems aligned with the paper's first three research questions. Frontier DeepSeek is the strongest single model, MT-DPO g0.4 sig is the strongest local learned model, and the open 3-way selector is the main reproducible workflow result. The closed 3-way catalog adjudicator is reported as an upper bound on recoverable complementarity. The full ablation matrix remains in the repository and does not change these conclusions.}}{7}{table.1}\protected@file@percent }
\newlabel{tab:main-results}{{1}{7}{Representative systems aligned with the paper's first three research questions. Frontier DeepSeek is the strongest single model, MT-DPO g0.4 sig is the strongest local learned model, and the open 3-way selector is the main reproducible workflow result. The closed 3-way catalog adjudicator is reported as an upper bound on recoverable complementarity. The full ablation matrix remains in the repository and does not change these conclusions}{table.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}RQ2: If local training still matters, what signal helps most?}{7}{subsection.5.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}RQ3: Can complementary failures be turned into a stronger workflow?}{7}{subsection.5.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Consolidated workflow comparison. ``F'' = frontier DeepSeek, ``UNK'' = UNK-SFT, and ``DPO'' = MT-DPO g0.4 sig. The deterministic selector is fully open and never edits text. The closed catalog adjudicator is reported as a stronger but less reproducible upper bound, while the oracle shows remaining headroom inside the same 3-way candidate pool.}}{8}{table.2}\protected@file@percent }
\newlabel{tab:oracle-complementarity}{{2}{8}{Consolidated workflow comparison. ``F'' = frontier DeepSeek, ``UNK'' = UNK-SFT, and ``DPO'' = MT-DPO g0.4 sig. The deterministic selector is fully open and never edits text. The closed catalog adjudicator is reported as a stronger but less reproducible upper bound, while the oracle shows remaining headroom inside the same 3-way candidate pool}{table.2}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6}Analysis}{8}{section.6}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.1}Why the workflow gain is conservative rather than verbose}{8}{subsection.6.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Why three candidates are enough}{8}{subsection.6.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Representative reference-aligned diagnostics derived from stored predictions. ``Contam.'' denotes mixed-script or prompt-artifact contamination. ``Suffix Preserve'' is computed on references containing at least one title-suffix character in \{{\CJKseriffont 經論記疏頌儀義傳錄贊序字品}\} and marks a prediction correct when it preserves all such reference-side suffix characters. The table is intended to show that the workflow gain comes from cleaner conservative title reconstruction rather than from verbose rewriting.}}{9}{table.3}\protected@file@percent }
\newlabel{tab:diagnostics}{{3}{9}{Representative reference-aligned diagnostics derived from stored predictions. ``Contam.'' denotes mixed-script or prompt-artifact contamination. ``Suffix Preserve'' is computed on references containing at least one title-suffix character in \{\zh {經論記疏頌儀義傳錄贊序字品}\} and marks a prediction correct when it preserves all such reference-side suffix characters. The table is intended to show that the workflow gain comes from cleaner conservative title reconstruction rather than from verbose rewriting}{table.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}Why reference-aware evaluation is necessary}{9}{subsection.6.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Representative reference-aware judge scores on a 1--5 scale. The judge sees the Tangut input, the gold reference, and the candidate output simultaneously, so this table is closer to the true task than the legacy reference-free judge.}}{10}{table.4}\protected@file@percent }
\newlabel{tab:reference-aware-eval}{{4}{10}{Representative reference-aware judge scores on a 1--5 scale. The judge sees the Tangut input, the gold reference, and the candidate output simultaneously, so this table is closer to the true task than the legacy reference-free judge}{table.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Paired bootstrap comparisons with 5,000 resamples. ``Overall'' denotes mean reference-aware judge score, and ``Exact'' denotes exact-match rate. The selected rows correspond to the paper's core claims: the open and closed workflow gains over frontier, the local DPO gain over MT-SFT, and the failure of legacy DPO.}}{10}{table.5}\protected@file@percent }
\newlabel{tab:statistical-robustness}{{5}{10}{Paired bootstrap comparisons with 5,000 resamples. ``Overall'' denotes mean reference-aware judge score, and ``Exact'' denotes exact-match rate. The selected rows correspond to the paper's core claims: the open and closed workflow gains over frontier, the local DPO gain over MT-SFT, and the failure of legacy DPO}{table.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.4}Why filtered DPO changes the local story}{10}{subsection.6.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Lightweight audit of the current DPO pair construction pipeline. Higher reward gaps correlate with cleaner preference labels under a simple gold-proxy check, which helps explain why strict filtering stabilizes the later multitask-base DPO runs.}}{11}{table.6}\protected@file@percent }
\newlabel{tab:dpo-audit}{{6}{11}{Lightweight audit of the current DPO pair construction pipeline. Higher reward gaps correlate with cleaner preference labels under a simple gold-proxy check, which helps explain why strict filtering stabilizes the later multitask-base DPO runs}{table.6}{}}
