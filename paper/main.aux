\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Representative systems for the first three research questions. Frontier DeepSeek is the strongest single model, MT-DPO g0.4 sig is the strongest local learned model, and the guarded open 3-way selector is the main reproducible workflow. Additional open controls appear in Table\nobreakspace  {}\ref  {tab:oracle-complementarity}; the closed adjudicator is reported only as headroom.}}{7}{table.1}\protected@file@percent }
\newlabel{tab:main-results}{{1}{7}{Representative systems for the first three research questions. Frontier DeepSeek is the strongest single model, MT-DPO g0.4 sig is the strongest local learned model, and the guarded open 3-way selector is the main reproducible workflow. Additional open controls appear in Table~\ref {tab:oracle-complementarity}; the closed adjudicator is reported only as headroom}{table.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Reviewer-facing local prompt/control comparison. The second row reuses the exact DeepSeek-style few-shot title prompt on Qwen2.5-7B; the third adds conservative lexical constrained beam search. Prompt alignment helps relative to the legacy local CoT prompt, but lexical constraints add only a marginal chrF++ gain.}}{7}{table.2}\protected@file@percent }
\newlabel{tab:local-prompt-controls}{{2}{7}{Reviewer-facing local prompt/control comparison. The second row reuses the exact DeepSeek-style few-shot title prompt on Qwen2.5-7B; the third adds conservative lexical constrained beam search. Prompt alignment helps relative to the legacy local CoT prompt, but lexical constraints add only a marginal chrF++ gain}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Workflow comparison with standard open reranking controls. ``F'' = frontier DeepSeek, ``UNK'' = UNK-SFT, and ``DPO'' = MT-DPO g0.4 sig. The guarded selector is the strongest clean open workflow; the closed adjudicator and oracle are upper bounds only.}}{8}{table.3}\protected@file@percent }
\newlabel{tab:oracle-complementarity}{{3}{8}{Workflow comparison with standard open reranking controls. ``F'' = frontier DeepSeek, ``UNK'' = UNK-SFT, and ``DPO'' = MT-DPO g0.4 sig. The guarded selector is the strongest clean open workflow; the closed adjudicator and oracle are upper bounds only}{table.3}{}}
