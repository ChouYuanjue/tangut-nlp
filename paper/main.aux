\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Representative systems aligned with the paper's first three research questions. Frontier DeepSeek is the strongest single model, MT-DPO g0.4 sig is the strongest local learned model, and the guarded open 3-way selector is the paper's designed overlap-oriented workflow. Additional open reranking controls are reported separately in Table\nobreakspace  {}\ref  {tab:oracle-complementarity}. The closed 3-way catalog adjudicator is reported only as an upper bound on recoverable complementarity. The full ablation matrix remains in the repository and does not change these conclusions.}}{7}{table.1}\protected@file@percent }
\newlabel{tab:main-results}{{1}{7}{Representative systems aligned with the paper's first three research questions. Frontier DeepSeek is the strongest single model, MT-DPO g0.4 sig is the strongest local learned model, and the guarded open 3-way selector is the paper's designed overlap-oriented workflow. Additional open reranking controls are reported separately in Table~\ref {tab:oracle-complementarity}. The closed 3-way catalog adjudicator is reported only as an upper bound on recoverable complementarity. The full ablation matrix remains in the repository and does not change these conclusions}{table.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}RQ3: Can Complementary Failures Be Turned into a Stronger Workflow?}{7}{subsection.5.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Workflow comparison with standard open reranking controls. ``F'' = frontier DeepSeek, ``UNK'' = UNK-SFT, and ``DPO'' = MT-DPO g0.4 sig. Plurality vote is the simplest exact-consensus control; the local Qwen reranker is an open learned selector that can only copy one candidate; pairwise chrF-MBR is a standard agreement-maximizing control. The guarded selector remains the strongest clean overlap-oriented open workflow, while the closed catalog adjudicator and oracle are reported only as upper bounds on additional recoverable complementarity.}}{8}{table.2}\protected@file@percent }
\newlabel{tab:oracle-complementarity}{{2}{8}{Workflow comparison with standard open reranking controls. ``F'' = frontier DeepSeek, ``UNK'' = UNK-SFT, and ``DPO'' = MT-DPO g0.4 sig. Plurality vote is the simplest exact-consensus control; the local Qwen reranker is an open learned selector that can only copy one candidate; pairwise chrF-MBR is a standard agreement-maximizing control. The guarded selector remains the strongest clean overlap-oriented open workflow, while the closed catalog adjudicator and oracle are reported only as upper bounds on additional recoverable complementarity}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Supplementary oracle-bone portability stress test on a 200-item held-out canonicalized OBIMD$\rightarrow $EVOBC test set. Inputs are real OBIMD sentence-level reading sequences mapped into the EVOBC ID inventory through shared modern-character labels. The probe target is a compact normalized decipherment string, so the multitask model is read through its \texttt  {<literal>} field. The open 2-way selector defaults to the dictionary-grounded prompt and switches to MT-SFT only under conservative contamination and short-repair conditions, lifting exact match from 40/200 to 44/200 while reducing contamination from 3.5\% to 0.5\%. The omitted raw MT-SFT assistant tail is a diagnostic mismatch control: 0/200 exact, 13.11 chrF++, and 100\% contamination.}}{8}{table.3}\protected@file@percent }
\newlabel{tab:oracle-portability}{{3}{8}{Supplementary oracle-bone portability stress test on a 200-item held-out canonicalized OBIMD$\rightarrow $EVOBC test set. Inputs are real OBIMD sentence-level reading sequences mapped into the EVOBC ID inventory through shared modern-character labels. The probe target is a compact normalized decipherment string, so the multitask model is read through its \texttt {<literal>} field. The open 2-way selector defaults to the dictionary-grounded prompt and switches to MT-SFT only under conservative contamination and short-repair conditions, lifting exact match from 40/200 to 44/200 while reducing contamination from 3.5\% to 0.5\%. The omitted raw MT-SFT assistant tail is a diagnostic mismatch control: 0/200 exact, 13.11 chrF++, and 100\% contamination}{table.3}{}}
